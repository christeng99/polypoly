# Copy snippets into your real environment (or a .env loader). Never commit secrets.
#
# === Multi-bot registry ===
# Comma-separated bot IDs; each bot must have POLY_BOT_<ID>_* variables (ID uppercased, '-' -> '_').
POLY_ACTIVE_BOTS=my_btc_bot,other_wallet

# === Global (optional) ===
# POLY_CLOB_HOST=https://clob.polymarket.com
# POLY_CHAIN_ID=137

# === Bot: my_btc_bot (env suffix MY_BTC_BOT) ===
# Markets: coin_leg pairs matching collector outcomes (Gamma uses up/down on 5m crypto markets).
POLY_BOT_MY_BTC_BOT_MARKETS=btc_up,btc_down

# EOA private key that signs orders (same pattern as Polymarket web / API docs).
POLY_BOT_MY_BTC_BOT_PRIVATE_KEY=0x...

# Funder = Polymarket proxy / Safe address displayed in the UI (maker on orders).
POLY_BOT_MY_BTC_BOT_FUNDER=0x...

# Thresholds on **mid** price (0–1). Leave one unset to disable that side.
POLY_BOT_MY_BTC_BOT_BUY_BELOW=0.35
# Optional ask band (order limit is always live best_ask):
# POLY_BOT_MY_BTC_BOT_BUY_PRICE=0.10   → allow BUY only if best_ask <= 0.10
# POLY_BOT_MY_BTC_BOT_BUY_PRICE_FRAC=0.9 → and skip if best_ask < 0.10*0.9 (=0.09)
# Omit BUY_PRICE: if only BUY_PRICE_FRAC is set, legacy rule: skip if best_ask > BUY_BELOW * FRAC.
POLY_BOT_MY_BTC_BOT_BUY_PRICE=0.10
POLY_BOT_MY_BTC_BOT_BUY_PRICE_FRAC=0.9
POLY_BOT_MY_BTC_BOT_SELL_ABOVE=0.72

# USDC notional per BUY (float). Runtime enforces at least ~$1. Share size = ONTIME_AMOUNT / current ask.
POLY_BOT_MY_BTC_BOT_ONTIME_AMOUNT=5

# FOK = fill-or-kill (good for one-shot intent); GTC/GTD per CLOB docs.
POLY_BOT_MY_BTC_BOT_ORDER_TYPE=FOK

# 2 = Gnosis Safe / Polymarket default for many accounts (match your account type).
POLY_BOT_MY_BTC_BOT_SIGNATURE_TYPE=2

# Taker fee rate in bps for this market/account (1000 = 10%).
POLY_BOT_MY_BTC_BOT_FEE_RATE_BPS=1000

# Limit BUY attempts to the first N seconds from round start.
# Set to 0 or leave unset to disable time-window limiting.
POLY_BOT_MY_BTC_BOT_BUY_LIMIT_SECS=0

# Minimum seconds between fired orders for this bot (per-process).
POLY_BOT_MY_BTC_BOT_COOLDOWN_SECS=30

# === Second bot example: other_wallet ===
# POLY_BOT_OTHER_WALLET_MARKETS=eth_up
# POLY_BOT_OTHER_WALLET_PRIVATE_KEY=0x...
# POLY_BOT_OTHER_WALLET_FUNDER=0x...
# POLY_BOT_OTHER_WALLET_BUY_BELOW=0.40
# POLY_BOT_OTHER_WALLET_ONTIME_AMOUNT=2
# POLY_BOT_OTHER_WALLET_ORDER_TYPE=FOK
# POLY_BOT_OTHER_WALLET_FEE_RATE_BPS=1000
# POLY_BOT_OTHER_WALLET_BUY_LIMIT_SECS=0

# To use this as local runtime config:
# 1) copy this file to `.env`
# 2) fill real values
# 3) run cargo as usual (`cargo run`)
